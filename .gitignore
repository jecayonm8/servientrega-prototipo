# ════════════════════════════════════════════════════════════
# .gitignore — Proyecto Servientrega
# ════════════════════════════════════════════════════════════

# ─── Node.js ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/

# ─── Variables de entorno (CRÍTICO: no subir credenciales) ─
.env
.env.local
.env.*.local
*.env

# ─── Docker ───────────────────────────────────────────────
.docker/

# ─── Editores e IDEs ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────
logs/
*.log

# ─── Build / Dist ─────────────────────────────────────────
dist/
build/
out/

# ─── Flutter / Dart (para cuando se agregue la app) ───────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/ios/Pods/
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/build/
mobile/android/local.properties

# ─── Sistema operativo ────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
desktop.ini

# ─── Archivos temporales del proyecto ─────────────────────
tmp/
temp/
*.tmp
*.bak
frontend/dist/
dist/
