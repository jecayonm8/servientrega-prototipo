# ════════════════════════════════════════════════════════════
# .env.example — Plantilla de variables de entorno
# Copia este archivo como .env y completa los valores
# ════════════════════════════════════════════════════════════

PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=servi_admin
DB_PASSWORD=cambia_esto_por_tu_password
DB_NAME=servientrega_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT
MQTT_BROKER=mqtt://localhost:1883


# ════════════════════════════════════════════════════════
# NOTA PARA USUARIOS DE WINDOWS CON POSTGRESQL LOCAL
# ════════════════════════════════════════════════════════
# Si tienes PostgreSQL instalado localmente en Windows,
# localhost:5432 puede ser interceptado por el servicio
# local antes de llegar al contenedor Docker.
#
# Solución: usa la IP de WSL2 en lugar de localhost:
#   DB_HOST=<IP de WSL2>
#
# Para obtener tu IP de WSL2 ejecuta en PowerShell:
#   wsl hostname -I
#
# Ejemplo: DB_HOST=172.31.233.211
#
# ⚠️ Esta IP cambia cada vez que reinicias Docker Desktop.
# ════════════════════════════════════════════════════════